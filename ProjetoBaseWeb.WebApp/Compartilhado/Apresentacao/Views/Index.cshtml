@{
    Layout = "_Layout";
    ViewBag.Titulo = "Página Inicial";
}

<div class="row g-2">
    <div class="col-lg-7">
        <h1 class="display-5 fw-semibold mb-3">ProjetoBase</h1>
        <p class="lead text-secondary mb-4">
            Lorem ipsum dolor, sit amet consectetur adipisicing elit. Totam facilis tempore magnam adipisci non
            blanditiis, reprehenderit aliquam unde! Reprehenderit voluptatibus perferendis cupiditate. Dolor, doloribus
            rerum id voluptates iure libero facilis.
        </p>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Home" asp-action="Index">Início</a>
            <a class="btn btn-primary rounded-pill px-4" asp-controller="ProjetoBase"
               asp-action="Listar">ProjetoBase</a>
        </div>

    </div>

    <div class="col-lg-5">
        <div class="card border-primary-subtle shadow-sm">
            <div class="card-body p-4">
